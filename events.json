---
layout: null
---
[
{%- assign now_time = site.time | date: "%s" | plus: 0 -%}
{%- assign skipped_event_paths = site.events | where_exp: "e", "e.path contains '.skip'" | map: "path" -%}
{%- assign is_first_item = true -%}
{% for event in site.events %}
{%- if event.path contains ".skip" -%}
  {%- continue -%}
{%- endif -%}
{%- assign event_skip_path = event.path | append: ".skip" -%}
{%- if skipped_event_paths contains event_skip_path -%}
  {%- continue -%}
{%- endif -%}
{%- assign event_time = event.dateIso | date:"%s" | plus: 0 -%}
{%- if event_time < now_time -%}
  {%- continue -%}
{%- endif -%}
  {%- unless is_first_item -%},{%- endunless -%}
  {%- assign is_first_item = false -%}
  {
    "Id": {{ event.id | jsonify }},
    "Href": {{ event.link | jsonify }},
    "Title": {{ event.title | strip | jsonify }},
    "Start": "{{ event.dateIso | date:"%Y-%m-%dT%T" }}",
    "Img": {{ site.site | append: "/" | append: site.baseurl | append: "/" | append: event.localImg | jsonify }},
    "Group": {{ event.community | strip | jsonify }},
    "Venue": {{ event.place | strip | jsonify }},
    "VenueAddr": {{ event.placeAddr | strip | jsonify }},
    "HtmlDescription": {{ event.content | strip | jsonify }}
  }
{% endfor %}
]